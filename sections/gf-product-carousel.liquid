{%- comment -%}
  ============================================================
  GREENFORM -- 360 Product Viewer
  Plant:   Monstera Thai Constellation
  Frames:  12

  INSTALL:
  1. Shopify Admin -> Themes -> Edit code
  2. sections/ -> Add new section -> name: product-360-viewer
     (only do this the first time; reuse the same section file for future plants)
  3. Paste this file -> Save
  4. Theme Editor -> Monstera Thai Constellation product page
     -> Add section -> "360 Product Viewer"
  5. Upload the 12 photos into the frame slots in order
  ============================================================
{%- endcomment -%}

{%- liquid
  assign frame_count = section.blocks | size
-%}

{% if frame_count > 0 %}

<div
  class="gf-360-section"
  id="gf360-{{ section.id }}"
  data-sens="{{ section.settings.sensitivity }}"
  data-auto-spin="{% if section.settings.auto_spin %}1{% else %}0{% endif %}"
  data-spin-speed="{{ section.settings.spin_speed }}"
>

  <div
    class="gf-360-viewer"
    id="gf360-viewer-{{ section.id }}"
    aria-label="360 product view -- drag or swipe to rotate"
    role="img"
  >

    {%- for block in section.blocks -%}
      {%- if block.type == 'frame' and block.settings.image != blank -%}
        <img
          class="gf-360-frame{%- if forloop.first %} is-active{%- endif -%}"
          src="{{ block.settings.image | image_url: width: 900 }}"
          alt="{{ section.settings.alt_text | escape }} -- frame {{ forloop.index }}"
          loading="{%- if forloop.first -%}eager{%- else -%}lazy{%- endif -%}"
          draggable="false"
          width="900" height="900"
          {{ block.shopify_attributes }}
        >
      {%- endif -%}
    {%- endfor -%}

    <div class="gf-360-hint" id="gf360-hint-{{ section.id }}" aria-hidden="true">
      <svg width="18" height="12" viewBox="0 0 18 12" fill="none">
        <path d="M1 6H17M1 6L5 2M1 6L5 10M17 6L13 2M17 6L13 10"
          stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>Drag to rotate</span>
    </div>

  </div>

  <div class="gf-360-scrubber" id="gf360-scrubber-{{ section.id }}" aria-hidden="true">
    <div class="gf-360-track">
      <div class="gf-360-thumb"></div>
    </div>
  </div>

</div>

{% endif %}

{%- style -%}
  #gf360-{{ section.id }} {
    --dot-active: {{ section.settings.dot_active_color }};
    --viewer-bg:  {{ section.settings.background_color }};
    --max-w:      {{ section.settings.max_width }}px;
    --radius:     {{ section.settings.border_radius }}px;
  }
  .gf-360-section     { width:100%; max-width:var(--max-w); margin:0 auto; }
  .gf-360-viewer      { position:relative; width:100%; aspect-ratio:1/1;
                        background:var(--viewer-bg); border-radius:var(--radius);
                        overflow:hidden; cursor:grab;
                        user-select:none; -webkit-user-select:none; touch-action:pan-y; }
  .gf-360-viewer:active { cursor:grabbing; }
  .gf-360-frame       { position:absolute; inset:0; width:100%; height:100%;
                        object-fit:{{ section.settings.object_fit }};
                        opacity:0; pointer-events:none; }
  .gf-360-frame.is-active { opacity:1; pointer-events:auto; }
  .gf-360-hint        { position:absolute; bottom:14px; left:50%; transform:translateX(-50%);
                        background:rgba(0,0,0,.65); backdrop-filter:blur(4px);
                        color:#fff; font-size:.72rem; font-weight:500;
                        padding:5px 14px 5px 11px; border-radius:100px;
                        display:flex; align-items:center; gap:7px;
                        pointer-events:none; white-space:nowrap; transition:opacity .5s; z-index:2; }
  .gf-360-hint.is-hidden { opacity:0; }
  .gf-360-scrubber    { margin:16px 4px 4px; padding:8px 0; position:relative;
                        cursor:pointer; touch-action:none; }
  .gf-360-track       { position:relative; height:2px; background:#e5e0d8; border-radius:2px; }
  .gf-360-thumb       { position:absolute; top:50%; left:0;
                        transform:translate(-50%, -50%);
                        width:14px; height:14px; background:var(--dot-active);
                        border-radius:50%; border:2px solid #fff;
                        box-shadow:0 1px 4px rgba(0,0,0,.15);
                        transition:left .12s ease; pointer-events:none; }
  .gf-360-scrubber.is-dragging .gf-360-thumb { transition:none; }
{%- endstyle -%}

<script>
(function() {
  var el = document.querySelector('.gf-360-section[data-auto-spin]:not([data-init])');
  if (!el) return;
  el.setAttribute('data-init', '1');

  var viewer    = el.querySelector('.gf-360-viewer');
  var hint      = el.querySelector('.gf-360-hint');
  var scrubber  = el.querySelector('.gf-360-scrubber');
  var track     = scrubber ? scrubber.querySelector('.gf-360-track') : null;
  var thumb     = scrubber ? scrubber.querySelector('.gf-360-thumb') : null;
  var frames    = Array.prototype.slice.call(viewer.querySelectorAll('.gf-360-frame'));
  var TOTAL     = frames.length;
  if (!TOTAL) return;

  var SENS       = parseInt(el.getAttribute('data-sens'), 10) || 4;
  var AUTO_SPIN  = el.getAttribute('data-auto-spin') === '1';
  var SPIN_SPEED = parseInt(el.getAttribute('data-spin-speed'), 10) || 80;
  var current    = 0;
  var hintDone   = false;

  function wrap(n) { return ((n % TOTAL) + TOTAL) % TOTAL; }

  function setThumb(i) {
    if (!thumb) return;
    thumb.style.left = (TOTAL > 1 ? (i / (TOTAL - 1)) * 100 : 50) + '%';
  }

  function show(idx) {
    var n = wrap(idx);
    if (n === current) return;
    frames[current].classList.remove('is-active');
    current = n;
    frames[current].classList.add('is-active');
    setThumb(current);
  }

  setThumb(0);

  function dimHint() {
    if (!hintDone && hint) { hint.classList.add('is-hidden'); hintDone = true; }
  }

  frames.forEach(function(img) {
    if (!img.complete) { new Image().src = img.src; }
  });

  // Viewer drag (rotates plant)
  var drag = false, lx = 0, acc = 0;
  viewer.addEventListener('mousedown', function(e) {
    drag = true; lx = e.clientX; acc = 0;
    viewer.style.cursor = 'grabbing'; dimHint(); e.preventDefault();
  });
  document.addEventListener('mousemove', function(e) {
    if (!drag) return;
    acc += e.clientX - lx; lx = e.clientX;
    var s = Math.trunc(acc / SENS);
    if (s) { show(current - s); acc -= s * SENS; }
  });
  document.addEventListener('mouseup', function() {
    drag = false; viewer.style.cursor = 'grab';
  });

  // Viewer touch
  var tx = 0, ta = 0;
  viewer.addEventListener('touchstart', function(e) {
    tx = e.touches[0].clientX; ta = 0; dimHint();
  }, {passive: true});
  viewer.addEventListener('touchmove', function(e) {
    var dx = e.touches[0].clientX - tx;
    tx = e.touches[0].clientX;
    ta += dx;
    var s = Math.trunc(ta / SENS);
    if (s) { e.preventDefault(); show(current - s); ta -= s * SENS; }
  }, {passive: false});

  // Scrubber click + drag
  if (scrubber && track) {
    var frameFromX = function(clientX) {
      var rect = track.getBoundingClientRect();
      var pct  = (clientX - rect.left) / rect.width;
      pct = Math.max(0, Math.min(1, pct));
      return Math.round(pct * (TOTAL - 1));
    };
    var scrubDrag = false;
    scrubber.addEventListener('mousedown', function(e) {
      scrubDrag = true;
      scrubber.classList.add('is-dragging');
      show(frameFromX(e.clientX));
      dimHint();
      e.preventDefault();
    });
    document.addEventListener('mousemove', function(e) {
      if (!scrubDrag) return;
      show(frameFromX(e.clientX));
    });
    document.addEventListener('mouseup', function() {
      if (!scrubDrag) return;
      scrubDrag = false;
      scrubber.classList.remove('is-dragging');
    });
    scrubber.addEventListener('touchstart', function(e) {
      scrubber.classList.add('is-dragging');
      show(frameFromX(e.touches[0].clientX));
      dimHint();
    }, {passive: true});
    scrubber.addEventListener('touchmove', function(e) {
      e.preventDefault();
      show(frameFromX(e.touches[0].clientX));
    }, {passive: false});
    scrubber.addEventListener('touchend', function() {
      scrubber.classList.remove('is-dragging');
    });
  }

  // Auto-spin once on load
  if (AUTO_SPIN) {
    var step = 0;
    var spin = setInterval(function() {
      step++;
      show(step);
      if (step >= TOTAL) clearInterval(spin);
    }, SPIN_SPEED);
    var stopSpin = function() { clearInterval(spin); };
    viewer.addEventListener('mousedown', stopSpin, {once: true});
    viewer.addEventListener('touchstart', stopSpin, {once: true, passive: true});
    if (scrubber) {
      scrubber.addEventListener('mousedown', stopSpin, {once: true});
      scrubber.addEventListener('touchstart', stopSpin, {once: true, passive: true});
    }
  }
}());
</script>

{%- schema -%}
{
  "name": "360° Product Viewer",
  "tag": "div",
  "class": "section-360-viewer",
  "limit": 1,
  "settings": [
    {"type": "paragraph", "content": "Upload each photo as a frame block below. Drag to reorder. Shoot every 30° for 12 frames."},
    {"type": "text",     "id": "alt_text",          "label": "Image alt text",          "default": "360° product view"},
    {"type": "header",   "content": "Layout"},
    {"type": "range",    "id": "max_width",          "label": "Max width (px)",          "min": 300, "max": 1200, "step": 50, "default": 700},
    {"type": "range",    "id": "border_radius",      "label": "Corner radius (px)",      "min": 0,   "max": 40,   "step": 2,  "default": 12},
    {"type": "select",   "id": "object_fit",         "label": "Image fit",
     "options": [{"value": "contain", "label": "Contain (show whole image)"}, {"value": "cover", "label": "Cover (fill box)"}],
     "default": "contain"},
    {"type": "color",    "id": "background_color",   "label": "Background colour",       "default": "#f8f6f2"},
    {"type": "header",   "content": "Scrubber"},
    {"type": "color",    "id": "dot_active_color",   "label": "Indicator dot colour",    "default": "#4a7c59"},
    {"type": "header",   "content": "Interaction"},
    {"type": "range",    "id": "sensitivity",        "label": "Drag sensitivity (px per frame)", "min": 1, "max": 15, "step": 1, "default": 4,
     "info": "Lower = more responsive."},
    {"type": "checkbox", "id": "auto_spin",          "label": "Auto-spin on page load",  "default": true},
    {"type": "range",    "id": "spin_speed",         "label": "Auto-spin speed (ms/frame)", "min": 40, "max": 300, "step": 10, "default": 80}
  ],
  "blocks": [
    {
      "type": "frame",
      "name": "Frame",
      "settings": [
        {"type": "image_picker", "id": "image", "label": "Frame image",
         "info": "One photo per frame. Square images work best (800x800px)."}
      ]
    }
  ],
  "presets": [
    {
      "name": "360° Product Viewer",
      "blocks": [
        { "type": "frame" },
        { "type": "frame" },
        { "type": "frame" },
        { "type": "frame" },
        { "type": "frame" },
        { "type": "frame" },
        { "type": "frame" },
        { "type": "frame" },
        { "type": "frame" },
        { "type": "frame" },
        { "type": "frame" },
        { "type": "frame" }
      ]
    }
  ]
}
{%- endschema -%}