{% comment %}
  Greenform — Trust Strip
  Three value proposition cards: guarantee, shipping, sourcing.
  Appears below the care card on product pages, and optionally on other pages.
  All content is editable through the theme customizer.
{% endcomment %}

<section class="trust-strip" id="TrustStrip-{{ section.id }}">
  <div class="trust-strip__grid">
    {%- for block in section.blocks -%}
      <div class="trust-strip__card" {{ block.shopify_attributes }}>
        <div class="trust-strip__icon">
          {%- case block.settings.icon -%}
            {%- when 'shield' -%}
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M12 2L4 6v5c0 5 3.4 9.7 8 11 4.6-1.3 8-6 8-11V6l-8-4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                <path d="M8.5 12L11 14.5 15.5 9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            {%- when 'truck' -%}
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M1 3h15v13H1z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                <path d="M16 8h4l3 4v4h-7V8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                <circle cx="5.5" cy="18" r="2" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="18.5" cy="18" r="2" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            {%- when 'leaf' -%}
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M6 21c0 0 1-9 9-13C19 6 21 3 21 3s-1 6-5 8c-8 4-9 10-9 10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M3 21c3-3 6-5 9-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            {%- when 'heart' -%}
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M12 21s-7-4.35-9-8C1 9.5 3 6 6.5 6c2 0 3.9 1.1 5.5 3.5C13.6 7.1 15.5 6 17.5 6 21 6 23 9.5 21 13c-2 3.65-9 8-9 8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
              </svg>
            {%- when 'star' -%}
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M12 2l3 6.2 6.8 1-5 4.8 1.2 6.8L12 17.8 6 20.8l1.2-6.8-5-4.8 6.8-1L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
              </svg>
            {%- else -%}
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
                <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            {%- endcase -%}
        </div>
        <h3 class="trust-strip__heading">{{ block.settings.heading }}</h3>
        <p class="trust-strip__text">{{ block.settings.text }}</p>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Trust strip",
  "tag": "section",
  "class": "section-trust-strip",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "trust_card",
      "name": "Trust card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Shield (guarantee)" },
            { "value": "truck", "label": "Truck (shipping)" },
            { "value": "leaf", "label": "Leaf (sourcing)" },
            { "value": "heart", "label": "Heart (care)" },
            { "value": "star", "label": "Star (quality)" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Happiness guarantee"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Your plants arrive healthy or we'll replace them, no questions asked."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust strip",
      "blocks": [
        {
          "type": "trust_card",
          "settings": {
            "icon": "shield",
            "heading": "Happiness guarantee",
            "text": "Your plants arrive healthy or we'll replace them, no questions asked."
          }
        },
        {
          "type": "trust_card",
          "settings": {
            "icon": "truck",
            "heading": "Free shipping over $120",
            "text": "Flat $15 NZ-wide for orders under the threshold. Rural surcharges may apply."
          }
        },
        {
          "type": "trust_card",
          "settings": {
            "icon": "leaf",
            "heading": "NZ grown and shipped",
            "text": "Sourced from trusted NZ growers. Packed with care and shipped fast, nationwide."
          }
        }
      ]
    }
  ]
}
{% endschema %}
