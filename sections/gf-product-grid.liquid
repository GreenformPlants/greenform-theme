<section class="gf-grid-section gf-section" id="gf-product-grid">
  <div class="gf-container">
    <div class="gf-grid-section__header gf-reveal">
      <h2 class="gf-grid-section__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="gf-grid-section__subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- assign collection = collections[section.settings.collection] -%}
    {%- assign products_to_show = section.settings.products_to_show -%}

    <div class="gf-product-grid gf-reveal gf-reveal--delay-1">
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: products_to_show -%}
          {%- render 'gf-product-card', card_product: product, show_quick_add: section.settings.enable_quick_add -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..products_to_show) -%}
          <article class="gf-card">
            <div class="gf-card__image-wrap">
              {{ 'product-1' | placeholder_svg_tag: 'gf-card__image placeholder-svg' }}
            </div>
            <div class="gf-card__info">
              <h3 class="gf-card__title"><a href="#">Example plant {{ i }}</a></h3>
              <p class="gf-card__botanical">Botanical name</p>
              <div class="gf-card__footer">
                <span class="gf-card__price">$49.00</span>
                <span class="gf-badge gf-badge--outline gf-card__difficulty">Easy</span>
              </div>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all and collection != blank -%}
      <div class="gf-grid-section__footer gf-reveal gf-reveal--delay-2">
        <a href="{{ collection.url }}" class="gf-btn gf-btn--outline">
          {{ section.settings.view_all_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Greenform Product Grid",
  "tag": "section",
  "class": "gf-grid-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our plants"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Hand-picked for New Zealand homes"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 6,
      "label": "Products to show"
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add",
      "label": "Enable quick add",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show \"View all\" link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all button text",
      "default": "View all plants"
    }
  ],
  "presets": [
    {
      "name": "Greenform Product Grid"
    }
  ]
}
{% endschema %}
