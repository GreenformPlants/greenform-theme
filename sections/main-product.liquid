{{ 'product-page.css' | asset_url | stylesheet_tag }}
{% comment %}
  Greenform — Main Product Section
  The primary product detail section: image gallery, title, price,
  variant selectors, metafield strip, add to cart, cross-sells.

  Metafield namespace: product.metafields.custom
  Required metafields: botanical_name, light_requirement, water_frequency,
    difficulty, pet_safe, plant_size, humidity, temperature, care_guide_url
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}

<section
  id="MainProduct-{{ section.id }}"
  class="product-section"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-product-url="{{ product.url }}"
>
  {%- comment -%} Breadcrumb {%- endcomment -%}
  <nav class="product-breadcrumb" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span aria-hidden="true">/</span>
    {%- if product.collections.size > 0 -%}
      {%- assign primary_collection = product.collections | first -%}
      <a href="{{ primary_collection.url }}">{{ primary_collection.title }}</a>
      <span aria-hidden="true">/</span>
    {%- endif -%}
    <span class="product-breadcrumb__current">{{ product.title }}</span>
  </nav>

  <div class="product-grid">

    {%- comment -%} ===== LEFT COLUMN: Image Gallery ===== {%- endcomment -%}
    <div class="product-gallery" id="ProductGallery-{{ section.id }}">
      <div class="product-gallery__main" id="ProductGalleryMain-{{ section.id }}">
        {%- if product.featured_media -%}
          <img
            src="{{ product.featured_media | image_url: width: 1200 }}"
            srcset="
              {{ product.featured_media | image_url: width: 600 }} 600w,
              {{ product.featured_media | image_url: width: 900 }} 900w,
              {{ product.featured_media | image_url: width: 1200 }} 1200w
            "
            sizes="(max-width: 768px) 100vw, 55vw"
            alt="{{ product.featured_media.alt | escape | default: product.title }}"
            width="{{ product.featured_media.width }}"
            height="{{ product.featured_media.height }}"
            loading="eager"
            id="ProductGalleryMainImage-{{ section.id }}"
          >
        {%- else -%}
          <div class="product-gallery__placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'product-gallery__placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      {%- if product.media.size > 1 -%}
        <div class="product-gallery__thumbs" id="ProductGalleryThumbs-{{ section.id }}">
          {%- for media in product.media -%}
            <button
              class="product-gallery__thumb{% if forloop.first %} product-gallery__thumb--active{% endif %}"
              data-media-id="{{ media.id }}"
              data-media-src="{{ media | image_url: width: 1200 }}"
              data-media-srcset="{{ media | image_url: width: 600 }} 600w, {{ media | image_url: width: 900 }} 900w, {{ media | image_url: width: 1200 }} 1200w"
              data-media-alt="{{ media.alt | escape | default: product.title }}"
              aria-label="View image {{ forloop.index }}"
              type="button"
            >
              <img
                src="{{ media | image_url: width: 150 }}"
                alt="{{ media.alt | escape | default: product.title }}"
                width="64"
                height="64"
                loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ===== RIGHT COLUMN: Product Info ===== {%- endcomment -%}
    <div class="product-info">

      {%- comment -%} Title and botanical name {%- endcomment -%}
      <h1 class="product-info__title">{{ product.title }}</h1>
      {%- if product.metafields.custom.botanical_name != blank -%}
        <p class="product-info__botanical">{{ product.metafields.custom.botanical_name }}</p>
      {%- endif -%}

      {%- comment -%} Price {%- endcomment -%}
      <div class="product-info__price-row" id="ProductPrice-{{ section.id }}">
        <span class="product-info__price" data-product-price>
          {{ current_variant.price | money }}
        </span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="product-info__compare-price" data-compare-price>
            {{ current_variant.compare_at_price | money }}
          </span>
          <span class="product-info__save-badge">
            Save {{ current_variant.compare_at_price | minus: current_variant.price | money }}
          </span>
        {%- endif -%}
        {%- unless current_variant.available -%}
          <span class="product-info__sold-out-badge">Sold out</span>
        {%- endunless -%}
        {%- if product.metafields.custom.stock_status != blank -%}
          <span class="product-info__stock-badge">{{ product.metafields.custom.stock_status }}</span>
        {%- endif -%}
      </div>

      {%- comment -%} Short description {%- endcomment -%}
      {%- if section.settings.show_short_description and product.description != blank -%}
        <div class="product-info__short-desc">
          {%- comment -%}
            Pulls the first paragraph from the product description.
            If your descriptions start with an H tag or different structure,
            you may want to use a dedicated metafield instead.
          {%- endcomment -%}
          {{ product.description | strip_html | truncatewords: 40 }}
        </div>
      {%- endif -%}

      {%- comment -%} Product form {%- endcomment -%}
      <product-form id="ProductForm-{{ section.id }}">
        {%- form 'product', product,
          id: 'ProductFormMain',
          class: 'product-form',
          novalidate: 'novalidate',
          data-type: 'add-to-cart-form'
        -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" id="ProductFormVariantId-{{ section.id }}">

          {%- comment -%} Size selector — auto-detects from variants {%- endcomment -%}
          {%- if section.settings.show_size_selector and product.variants.size > 1 -%}
            {%- for option in product.options_with_values -%}
              <div class="product-form__selector">
                <p class="product-form__selector-label">{{ option.name }}</p>
                <div class="product-form__size-options" data-option-position="{{ option.position }}">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="product-form__size-pill{% if value == option.selected_value %} product-form__size-pill--active{% endif %}"
                      data-option-value="{{ value | escape }}"
                      data-option-position="{{ option.position }}"
                      aria-label="Select {{ option.name }}: {{ value }}"
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}

          {%- comment -%} Pot add-on selector {%- endcomment -%}
          {%- if section.settings.show_pot_selector -%}
            <div class="product-form__selector product-form__pot-selector" id="PotSelector-{{ section.id }}">
              <p class="product-form__selector-label">Add a pot</p>
              <div class="product-form__pot-options">
                <button type="button" class="product-form__pot-chip product-form__pot-chip--none product-form__pot-chip--active" data-pot-id="none" aria-label="No pot">
                  <span class="product-form__pot-chip-icon">
                    <svg viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M6 10 L10 24 L18 24 L22 10 Z" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
                  </span>
                </button>
                {%- for block in section.blocks -%}
                  {%- if block.type == 'pot_option' -%}
                    <button
                      type="button"
                      class="product-form__pot-chip"
                      data-pot-id="{{ block.settings.pot_product | default: block.id }}"
                      data-pot-variant-id="{{ block.settings.pot_variant_id }}"
                      data-pot-price="{{ block.settings.pot_price | times: 100 }}"
                      aria-label="Add {{ block.settings.pot_name }}"
                      {{ block.shopify_attributes }}
                    >
                      {%- if block.settings.pot_image != blank -%}
                        <img
                          src="{{ block.settings.pot_image | image_url: width: 80 }}"
                          alt="{{ block.settings.pot_name | escape }}"
                          width="36"
                          height="36"
                          loading="lazy"
                        >
                      {%- else -%}
                        <span class="product-form__pot-chip-icon">
                          <svg viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="4" y="8" width="20" height="16" rx="3" fill="currentColor" opacity="0.15"/><rect x="6" y="6" width="16" height="4" rx="2" fill="currentColor" opacity="0.25"/></svg>
                        </span>
                      {%- endif -%}
                    </button>
                    <p class="product-form__pot-chip-label">{{ block.settings.pot_name }}</p>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Metafield strip {%- endcomment -%}
          {%- if section.settings.show_metafield_strip -%}
            {%- assign has_metafields = false -%}
            {%- if product.metafields.custom.light_requirement != blank
              or product.metafields.custom.water_frequency != blank
              or product.metafields.custom.difficulty != blank
              or product.metafields.custom.plant_size != blank
            -%}
              {%- assign has_metafields = true -%}
            {%- endif -%}

            {%- if has_metafields -%}
              <div class="product-metafield-strip">
                {%- if product.metafields.custom.light_requirement != blank -%}
                  <div class="product-metafield-strip__item">
                    <span class="product-metafield-strip__label">Light</span>
                    <span class="product-metafield-strip__value">{{ product.metafields.custom.light_requirement }}</span>
                  </div>
                {%- endif -%}
                {%- if product.metafields.custom.water_frequency != blank -%}
                  <div class="product-metafield-strip__item">
                    <span class="product-metafield-strip__label">Water</span>
                    <span class="product-metafield-strip__value">{{ product.metafields.custom.water_frequency }}</span>
                  </div>
                {%- endif -%}
                {%- if product.metafields.custom.difficulty != blank -%}
                  <div class="product-metafield-strip__item">
                    <span class="product-metafield-strip__label">Difficulty</span>
                    <span class="product-metafield-strip__value">{{ product.metafields.custom.difficulty }}</span>
                  </div>
                {%- endif -%}
                {%- if product.metafields.custom.plant_size != blank -%}
                  <div class="product-metafield-strip__item">
                    <span class="product-metafield-strip__label">Size</span>
                    <span class="product-metafield-strip__value">{{ product.metafields.custom.plant_size }}</span>
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endif -%}

          {%- comment -%} Quantity and Add to Cart {%- endcomment -%}
          <div class="product-form__actions">
            <div class="product-form__qty" id="ProductQty-{{ section.id }}">
              <button type="button" class="product-form__qty-btn" data-qty-change="-1" aria-label="Decrease quantity">−</button>
              <input
                type="number"
                name="quantity"
                id="ProductQtyInput-{{ section.id }}"
                class="product-form__qty-input"
                value="1"
                min="1"
                aria-label="Quantity"
              >
              <button type="button" class="product-form__qty-btn" data-qty-change="1" aria-label="Increase quantity">+</button>
            </div>
            <button
              type="submit"
              name="add"
              class="product-form__atc-btn"
              id="ProductSubmitButton-{{ section.id }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {%- if current_variant.available -%}
                Add to cart <span class="product-form__atc-price" data-atc-price>{{ current_variant.price | money }}</span>
              {%- else -%}
                Sold out
              {%- endif -%}
            </button>
          </div>

        {%- endform -%}
      </product-form>

      {%- comment -%} Shipping confidence line {%- endcomment -%}
      {%- if section.settings.show_shipping_line -%}
        <div class="product-info__shipping-line">
          {%- if section.settings.shipping_line_left != blank -%}
            <span>{{ section.settings.shipping_line_left }}</span>
          {%- endif -%}
          {%- if section.settings.shipping_line_left != blank and section.settings.shipping_line_right != blank -%}
            <span class="product-info__shipping-divider" aria-hidden="true">|</span>
          {%- endif -%}
          {%- if section.settings.shipping_line_right != blank -%}
            <span>{{ section.settings.shipping_line_right }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} Cross-sell recommendations {%- endcomment -%}
      {%- if section.settings.show_cross_sells -%}
        {%- assign cross_sell_blocks = section.blocks | where: 'type', 'cross_sell' -%}
        {%- if cross_sell_blocks.size > 0 -%}
          <div class="product-cross-sell" id="ProductCrossSell-{{ section.id }}">
            <p class="product-cross-sell__title">{{ section.settings.cross_sell_heading | default: 'Complete the look' }}</p>
            {%- for block in cross_sell_blocks -%}
              {%- assign cs_product = block.settings.cross_sell_product -%}
              {%- if cs_product != blank -%}
                <div class="product-cross-sell__item" data-cross-sell-variant-id="{{ cs_product.selected_or_first_available_variant.id }}" {{ block.shopify_attributes }}>
                  <div class="product-cross-sell__img">
                    {%- if cs_product.featured_image != blank -%}
                      <img
                        src="{{ cs_product.featured_image | image_url: width: 120 }}"
                        alt="{{ cs_product.featured_image.alt | escape | default: cs_product.title }}"
                        width="48"
                        height="48"
                        loading="lazy"
                      >
                    {%- endif -%}
                  </div>
                  <div class="product-cross-sell__info">
                    <p class="product-cross-sell__name">{{ cs_product.title }}</p>
                    {%- if block.settings.cross_sell_description != blank -%}
                      <p class="product-cross-sell__desc">{{ block.settings.cross_sell_description }}</p>
                    {%- endif -%}
                  </div>
                  <span class="product-cross-sell__price">{{ cs_product.price | money }}</span>
                  <button
                    type="button"
                    class="product-cross-sell__add-btn"
                    data-cross-sell-add
                    data-variant-id="{{ cs_product.selected_or_first_available_variant.id }}"
                    aria-label="Add {{ cs_product.title }} to cart"
                  >
                    Add
                  </button>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endif -%}

    </div>
  </div>

  {%- comment -%} Product description — full body, below the fold on mobile {%- endcomment -%}
  {%- if product.description != blank -%}
    <div class="product-description" id="ProductDescription-{{ section.id }}">
      <h2 class="product-description__heading">About this plant</h2>
      <div class="product-description__body rte">
        {{ product.description }}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} Variant JSON for JS {%- endcomment -%}
  <script type="application/json" id="ProductJSON-{{ section.id }}">
    {{ product.variants | json }}
  </script>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('MainProduct-{{ section.id }}');
    if (!section) return;

    const variantData = JSON.parse(
      document.getElementById('ProductJSON-{{ section.id }}').textContent
    );

    /* ---- Thumbnail gallery ---- */
    const thumbs = section.querySelectorAll('.product-gallery__thumb');
    const mainImage = document.getElementById('ProductGalleryMainImage-{{ section.id }}');

    thumbs.forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        thumbs.forEach(function(t) { t.classList.remove('product-gallery__thumb--active'); });
        thumb.classList.add('product-gallery__thumb--active');
        if (mainImage) {
          mainImage.src = thumb.dataset.mediaSrc;
          mainImage.srcset = thumb.dataset.mediaSrcset;
          mainImage.alt = thumb.dataset.mediaAlt;
        }
      });
    });

    /* ---- Variant selection (pill buttons) ---- */
    const pills = section.querySelectorAll('.product-form__size-pill');
    const variantIdInput = document.getElementById('ProductFormVariantId-{{ section.id }}');
    const priceEl = section.querySelector('[data-product-price]');
    const atcPriceEl = section.querySelector('[data-atc-price]');
    const submitBtn = document.getElementById('ProductSubmitButton-{{ section.id }}');

    let selectedOptions = {};
    pills.forEach(function(pill) {
      if (pill.classList.contains('product-form__size-pill--active')) {
        selectedOptions[pill.dataset.optionPosition] = pill.dataset.optionValue;
      }
    });

    pills.forEach(function(pill) {
      pill.addEventListener('click', function() {
        var position = pill.dataset.optionPosition;
        var siblings = section.querySelectorAll('[data-option-position="' + position + '"].product-form__size-pill');
        siblings.forEach(function(s) { s.classList.remove('product-form__size-pill--active'); });
        pill.classList.add('product-form__size-pill--active');
        selectedOptions[position] = pill.dataset.optionValue;
        updateVariant();
      });
    });

    function updateVariant() {
      var optionValues = [];
      for (var i = 1; i <= 3; i++) {
        if (selectedOptions[i]) optionValues.push(selectedOptions[i]);
      }

      var matched = variantData.find(function(v) {
        return optionValues.every(function(val, idx) {
          return v.options[idx] === val;
        });
      });

      if (matched) {
        variantIdInput.value = matched.id;
        var formattedPrice = Shopify.formatMoney(matched.price, window.theme.moneyFormat || '${{amount}}');
        if (priceEl) priceEl.textContent = formattedPrice;
        if (atcPriceEl) atcPriceEl.textContent = formattedPrice;

        if (matched.available) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = 'Add to cart <span class="product-form__atc-price" data-atc-price>' + formattedPrice + '</span>';
        } else {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Sold out';
        }

        /* Update URL without reload */
        var url = new URL(window.location);
        url.searchParams.set('variant', matched.id);
        history.replaceState({}, '', url);

        /* Update gallery if variant has featured image */
        if (matched.featured_image && mainImage) {
          mainImage.src = matched.featured_image.src;
        }
      }
    }

    /* ---- Quantity buttons ---- */
    var qtyBtns = section.querySelectorAll('[data-qty-change]');
    var qtyInput = document.getElementById('ProductQtyInput-{{ section.id }}');

    qtyBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var change = parseInt(btn.dataset.qtyChange);
        var current = parseInt(qtyInput.value) || 1;
        var newVal = Math.max(1, current + change);
        qtyInput.value = newVal;
      });
    });

    /* ---- Cross-sell add buttons ---- */
    var crossSellBtns = section.querySelectorAll('[data-cross-sell-add]');
    crossSellBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var variantId = btn.dataset.variantId;
        fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: [{ id: parseInt(variantId), quantity: 1 }] })
        })
        .then(function(response) { return response.json(); })
        .then(function() {
          btn.textContent = 'Added';
          btn.disabled = true;
          setTimeout(function() {
            btn.textContent = 'Add';
            btn.disabled = false;
          }, 2000);
          /* Dispatch event for cart drawer to pick up */
          document.dispatchEvent(new CustomEvent('cart:updated'));
        })
        .catch(function(err) {
          console.error('Cross-sell add error:', err);
        });
      });
    });

    /* ---- Ajax add to cart (main form) ---- */
    var mainForm = document.getElementById('ProductFormMain');
    if (mainForm) {
      mainForm.addEventListener('submit', function(e) {
        e.preventDefault();
        var formData = new FormData(mainForm);
        var body = {
          items: [{
            id: parseInt(formData.get('id')),
            quantity: parseInt(formData.get('quantity')) || 1
          }]
        };

        submitBtn.disabled = true;
        submitBtn.textContent = 'Adding...';

        fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        })
        .then(function(response) { return response.json(); })
        .then(function() {
          submitBtn.textContent = 'Added to cart';
          setTimeout(function() {
            submitBtn.disabled = false;
            var price = priceEl ? priceEl.textContent : '';
            submitBtn.innerHTML = 'Add to cart <span class="product-form__atc-price" data-atc-price>' + price + '</span>';
          }, 1500);
          document.dispatchEvent(new CustomEvent('cart:updated'));
        })
        .catch(function(err) {
          console.error('Add to cart error:', err);
          submitBtn.disabled = false;
          submitBtn.textContent = 'Try again';
        });
      });
    }

    /* ---- Pot selector chips ---- */
    var potChips = section.querySelectorAll('.product-form__pot-chip');
    potChips.forEach(function(chip) {
      chip.addEventListener('click', function() {
        potChips.forEach(function(c) { c.classList.remove('product-form__pot-chip--active'); });
        chip.classList.add('product-form__pot-chip--active');
      });
    });
  });
</script>

{% schema %}
{
  "name": "Product details",
  "tag": "section",
  "class": "section-product-details",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "show_short_description",
      "label": "Show short description",
      "default": true,
      "info": "Displays a truncated version of the product description above the selectors."
    },
    {
      "type": "checkbox",
      "id": "show_size_selector",
      "label": "Show variant selectors",
      "default": true,
      "info": "Automatically hidden if the product has only one variant."
    },
    {
      "type": "checkbox",
      "id": "show_pot_selector",
      "label": "Show pot add-on selector",
      "default": true,
      "info": "Displays pot options configured as blocks below."
    },
    {
      "type": "checkbox",
      "id": "show_metafield_strip",
      "label": "Show care-at-a-glance strip",
      "default": true,
      "info": "Displays light, water, difficulty, and size from product metafields."
    },
    {
      "type": "checkbox",
      "id": "show_cross_sells",
      "label": "Show cross-sell recommendations",
      "default": true
    },
    {
      "type": "text",
      "id": "cross_sell_heading",
      "label": "Cross-sell heading",
      "default": "Complete the look"
    },
    {
      "type": "header",
      "content": "Shipping confidence"
    },
    {
      "type": "checkbox",
      "id": "show_shipping_line",
      "label": "Show shipping info line",
      "default": true
    },
    {
      "type": "text",
      "id": "shipping_line_left",
      "label": "Shipping line — left text",
      "default": "Free shipping over $120"
    },
    {
      "type": "text",
      "id": "shipping_line_right",
      "label": "Shipping line — right text",
      "default": "Arrives in 2–4 days"
    }
  ],
  "blocks": [
    {
      "type": "pot_option",
      "name": "Pot option",
      "settings": [
        {
          "type": "text",
          "id": "pot_name",
          "label": "Pot name",
          "default": "Ceramic"
        },
        {
          "type": "product",
          "id": "pot_product",
          "label": "Pot product"
        },
        {
          "type": "text",
          "id": "pot_variant_id",
          "label": "Pot variant ID",
          "info": "The numeric variant ID of the pot to add to cart."
        },
        {
          "type": "text",
          "id": "pot_price",
          "label": "Pot display price",
          "info": "e.g. 34.00"
        },
        {
          "type": "image_picker",
          "id": "pot_image",
          "label": "Pot image"
        }
      ]
    },
    {
      "type": "cross_sell",
      "name": "Cross-sell product",
      "settings": [
        {
          "type": "product",
          "id": "cross_sell_product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "cross_sell_description",
          "label": "Short description",
          "info": "One-liner shown under the product name."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product details",
      "blocks": []
    }
  ]
}
