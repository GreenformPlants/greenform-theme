{%- comment -%}
  Greenform Footer
  Replaces Dawn's stock footer. Purpose-built layout:
  Column 1: Brand (logo/name + tagline)
  Column 2-3: Navigation link lists (configurable via blocks)
  Column 4: Newsletter signup
  Bottom bar: Copyright + payment icons
{%- endcomment -%}

<style>
  .gf-footer {
    background-color: var(--gf-green-hero, #1b4332);
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--gf-font-body, 'DM Sans', sans-serif);
  }

  .gf-footer a {
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .gf-footer a:hover {
    color: #fff;
  }

  .gf-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(3rem, 2.5rem + 3vw, 5rem) clamp(1rem, 0.5rem + 2vw, 2rem);
  }

  .gf-footer__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.3fr;
    gap: clamp(2rem, 1.5rem + 2vw, 4rem);
  }

  @media (max-width: 990px) {
    .gf-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem 2rem;
    }
  }

  @media (max-width: 480px) {
    .gf-footer__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* Brand column */
  .gf-footer__brand-name {
    font-family: var(--gf-font-display, 'Playfair Display', serif);
    font-size: clamp(1.25rem, 1rem + 0.5vw, 1.5rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .gf-footer__brand-name a {
    color: #fff;
  }

  .gf-footer__brand-logo {
    height: clamp(24px, 2vw + 16px, 36px);
    width: auto;
  }

  .gf-footer__tagline {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 1.5rem;
    max-width: 280px;
  }

  /* Social icons */
  .gf-footer__social {
    display: flex;
    gap: 0.5rem;
  }

  .gf-footer__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.6);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .gf-footer__social a:hover {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }

  .gf-footer__social svg {
    width: 18px;
    height: 18px;
  }

  /* Link columns */
  .gf-footer__heading {
    font-family: var(--gf-font-body, 'DM Sans', sans-serif);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.4);
    margin: 0 0 1.25rem;
  }

  .gf-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .gf-footer__links a {
    font-size: 0.9375rem;
    display: inline-block;
    padding: 0.125rem 0;
  }

  /* Newsletter */
  .gf-footer__newsletter-text {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0 0 1rem;
    line-height: 1.5;
  }

  .gf-footer__newsletter-form {
    display: flex;
    gap: 0.5rem;
  }

  @media (max-width: 480px) {
    .gf-footer__newsletter-form {
      flex-direction: column;
    }
  }

  .gf-footer__newsletter-input {
    flex: 1;
    font-family: var(--gf-font-body, 'DM Sans', sans-serif);
    font-size: 0.875rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 980px;
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .gf-footer__newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }

  .gf-footer__newsletter-input:focus {
    border-color: rgba(255, 255, 255, 0.4);
  }

  .gf-footer__newsletter-btn {
    font-family: var(--gf-font-body, 'DM Sans', sans-serif);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    background: var(--gf-green, #2d6a4f);
    color: #fff;
    border: none;
    border-radius: 980px;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.2s ease;
  }

  .gf-footer__newsletter-btn:hover {
    background: var(--gf-green-light, #40916c);
  }

  .gf-footer__newsletter-msg {
    font-size: 0.8125rem;
    margin-top: 0.625rem;
  }

  /* Bottom bar */
  .gf-footer__bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem clamp(1rem, 0.5rem + 2vw, 2rem);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .gf-footer__copyright {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.3);
    margin: 0;
  }

  .gf-footer__copyright a {
    color: rgba(255, 255, 255, 0.4);
  }
  .gf-footer__copyright a:hover {
    color: rgba(255, 255, 255, 0.6);
  }

  .gf-footer__payments {
    display: flex;
    gap: 0.375rem;
    align-items: center;
    opacity: 0.45;
  }

  .gf-footer__payments svg {
    height: 24px;
    width: auto;
  }
</style>

<footer class="gf-footer">
  <div class="gf-footer__inner">
    <div class="gf-footer__grid">

      {%- comment -%} Column 1: Brand {%- endcomment -%}
      <div class="gf-footer__col">
        <div class="gf-footer__brand-name">
          <a href="{{ routes.root_url }}">
            {%- if settings.logo != blank -%}
              <img
                src="{{ settings.logo | image_url: width: 200 }}"
                alt="{{ settings.logo.alt | default: shop.name | escape }}"
                class="gf-footer__brand-logo"
                loading="lazy"
              >
            {%- else -%}
              {{ shop.name }}
            {%- endif -%}
          </a>
        </div>
        {%- if section.settings.tagline != blank -%}
          <p class="gf-footer__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}

        {%- comment -%} Social icons {%- endcomment -%}
        <div class="gf-footer__social">
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" aria-label="Instagram" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_facebook_link != blank -%}
            <a href="{{ settings.social_facebook_link }}" aria-label="Facebook" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}
            <a href="{{ settings.social_tiktok_link }}" aria-label="TikTok" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78 2.92 2.92 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 3 15.57 6.33 6.33 0 0 0 9.37 22a6.33 6.33 0 0 0 6.37-6.23V9.06a8.16 8.16 0 0 0 3.85.96V6.69z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_pinterest_link != blank -%}
            <a href="{{ settings.social_pinterest_link }}" aria-label="Pinterest" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M8 12a4 4 0 1 1 8 0c0 4-3 6-3 6"/><line x1="12" y1="12" x2="10" y2="21"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Link columns (blocks) {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div class="gf-footer__col" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h3 class="gf-footer__heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="gf-footer__links">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} Newsletter column {%- endcomment -%}
      {%- if section.settings.show_newsletter -%}
        <div class="gf-footer__col">
          <h3 class="gf-footer__heading">{{ section.settings.newsletter_heading }}</h3>
          {%- if section.settings.newsletter_text != blank -%}
            <p class="gf-footer__newsletter-text">{{ section.settings.newsletter_text }}</p>
          {%- endif -%}
          {%- form 'customer', id: 'GfFooterNewsletter' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="gf-footer__newsletter-form">
              <input
                type="email"
                name="contact[email]"
                class="gf-footer__newsletter-input"
                placeholder="{{ section.settings.newsletter_placeholder }}"
                required
                autocomplete="email"
                aria-label="Email address"
                {% if form.errors %}
                  autofocus aria-invalid="true"
                {% endif %}
              >
              <button type="submit" class="gf-footer__newsletter-btn">
                {{ section.settings.newsletter_button }}
              </button>
            </div>
            {%- if form.posted_successfully? -%}
              <p class="gf-footer__newsletter-msg" style="color: var(--gf-green-soft, #d8f3dc);">
                {{ section.settings.newsletter_success }}
              </p>
            {%- endif -%}
            {%- if form.errors -%}
              <p class="gf-footer__newsletter-msg" style="color: #f4a261;">
                {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
              </p>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

    </div>
  </div>

  {%- comment -%} Bottom bar {%- endcomment -%}
  <div class="gf-footer__bottom">
    <p class="gf-footer__copyright">
      &copy; {{ 'now' | date: '%Y' }} <a href="{{ routes.root_url }}">{{ shop.name }}</a>. All rights reserved.
    </p>

    {%- if section.settings.show_payment_icons -%}
      <div class="gf-footer__payments">
        {{ shop.enabled_payment_types | payment_type_svg_tag }}
      </div>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "Greenform Footer",
  "class": "gf-footer-section",
  "settings": [
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Premium houseplants, safely shipped to your door anywhere in New Zealand."
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter text",
      "default": "Care tips, new arrivals, and the occasional exclusive offer."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email placeholder",
      "default": "Your email"
    },
    {
      "type": "text",
      "id": "newsletter_button",
      "label": "Submit button text",
      "default": "Join"
    },
    {
      "type": "text",
      "id": "newsletter_success",
      "label": "Success message",
      "default": "Welcome aboard!"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Link column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "Shop",
          "menu": "main-menu"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Help",
          "menu": "footer"
        }
      }
    ]
  }
}
{% endschema %}
