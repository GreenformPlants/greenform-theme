<section class="gf-testimonials gf-section" id="gf-testimonials">
  <div class="gf-container">
    <div class="gf-testimonials__header gf-reveal">
      <h2 class="gf-testimonials__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="gf-testimonials__subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  </div>

  <div class="gf-container gf-container--wide">
    <div class="gf-testimonials__track gf-reveal gf-reveal--delay-1">
      {%- for block in section.blocks -%}
        <div class="gf-testimonial-card" {{ block.shopify_attributes }}>
          <div class="gf-testimonial-card__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {%- for i in (1..5) -%}
              {%- if i <= block.settings.rating -%}
                <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <p class="gf-testimonial-card__text">{{ block.settings.text }}</p>
          <div class="gf-testimonial-card__author">{{ block.settings.author }}</div>
          {%- if block.settings.plant != blank -%}
            <div class="gf-testimonial-card__plant">Purchased: {{ block.settings.plant }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Greenform Testimonials",
  "tag": "section",
  "class": "gf-testimonials-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real reviews from real plant lovers"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Star rating"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "My Monstera arrived in perfect condition. Beautifully packaged and clearly well looked after. Already planning my next order."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sarah T."
        },
        {
          "type": "text",
          "id": "plant",
          "label": "Plant purchased",
          "default": "Monstera Deliciosa"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Greenform Testimonials",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "text": "My Monstera arrived in perfect condition. Beautifully packaged and clearly well looked after. Already planning my next order.",
            "author": "Sarah T.",
            "plant": "Monstera Deliciosa"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "text": "The care guide that came with my Fiddle Leaf Fig has been a lifesaver. Three months in and it's thriving. Best plant purchase I've made.",
            "author": "James K.",
            "plant": "Fiddle Leaf Fig"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "text": "Fast shipping to Wellington and the plant was packed so carefully. Love that they include specific care instructions for NZ conditions.",
            "author": "Aroha M.",
            "plant": "Alocasia Zebrina"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 4,
            "text": "Great selection of rare plants. The Thai Constellation was exactly as pictured. Would love to see more pot options in future.",
            "author": "Daniel W.",
            "plant": "Thai Constellation"
          }
        }
      ]
    }
  ]
}
{% endschema %}
